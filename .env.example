# Admin
ADMIN_API_KEY=your-secret-admin-api-key

# Database
DATABASE_PATH=./data/kyc.db

# File Storage
UPLOAD_DIR=./uploads
TEMPLATE_DIR=./templates

# Base URL
BASE_URL=http://localhost:3000

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
